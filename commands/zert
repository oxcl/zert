# Main dispatcher function - autoloaded on first call

zert() {
  local cmd="$1"

  if [[ -z "$cmd" ]]; then
    _zert_ui_error "Usage: zert <command> [args...]"
    return 1
  fi

  shift

  # Dispatch to subcommand handler (autoloaded from commands/)
  if functions "_zert_cmd_$cmd" >/dev/null 2>&1; then
    "_zert_cmd_$cmd" "$@"
  else
    # Try to parse as plugin source
    if _zert_parse_source "$cmd"; then 
      _zert_plugin_add "$__ZERT_SOURCE_TYPE" "$__ZERT_SOURCE_VALUE" "$@"
    else
      _zert_ui_error "Unknown command: $cmd"
      return 1
    fi
  fi
}
