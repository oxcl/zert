_zert_cmd_help() {
  print "${__ZERT_CLR_BOLD}zert${__ZERT_CLR_RESET} ${__ZERT_CLR_GRAY}v${ZERT_VERSION}${__ZERT_CLR_RESET}"
  print ""
  print "${__ZERT_CLR_BOLD}USAGE${__ZERT_CLR_RESET}"
  print "  zert <command> [args...]"
  print "  zert <plugin-source> [flags]"
  print ""
  print "${__ZERT_CLR_BOLD}SUBCOMMANDS${__ZERT_CLR_RESET}"
  print "  ${__ZERT_CLR_GREEN}list${__ZERT_CLR_RESET}            List all loaded plugins"
  print "  ${__ZERT_CLR_GREEN}update${__ZERT_CLR_RESET}          Pull latest commits for unpinned plugins"
  print "  ${__ZERT_CLR_GREEN}prune${__ZERT_CLR_RESET}           Remove plugins no longer declared in config"
  print "  ${__ZERT_CLR_GREEN}use${__ZERT_CLR_RESET}             Initialize a framework (ohmyzsh, prezto)"
  print "  ${__ZERT_CLR_GREEN}ohmyzsh${__ZERT_CLR_RESET}         Load an Oh-My-Zsh component"
  print "  ${__ZERT_CLR_GREEN}prezto${__ZERT_CLR_RESET}          Load a Prezto module"
  print "  ${__ZERT_CLR_GREEN}help${__ZERT_CLR_RESET}            Show this help message"
  print ""
  print "${__ZERT_CLR_BOLD}FLAGS${__ZERT_CLR_RESET}"
  print "  ${__ZERT_CLR_CYAN}--help${__ZERT_CLR_RESET}, ${__ZERT_CLR_CYAN}-h${__ZERT_CLR_RESET}      Show this help message"
  print "  ${__ZERT_CLR_CYAN}--version${__ZERT_CLR_RESET}, ${__ZERT_CLR_CYAN}-v${__ZERT_CLR_RESET}   Show version number"
  print ""
  print "${__ZERT_CLR_BOLD}PLUGIN SOURCES${__ZERT_CLR_RESET}"
  print "  zert zsh-users/zsh-autosuggestions"
  print "  zert https://github.com/user/repo"
  print "  zert /absolute/path/to/plugin"
  print "  zert zsh-users/zsh-completions --branch main"
  print "  zert zsh-users/zsh-autosuggestions --pin <sha>"
  print "  zert use ohmyzsh && zert ohmyzsh plugins/git"
  print "  zert use prezto && zert prezto modules/utility"
  print ""
  print "${__ZERT_CLR_BOLD}PLUGIN FLAGS${__ZERT_CLR_RESET}"
  print "  ${__ZERT_CLR_CYAN}--no-alias${__ZERT_CLR_RESET}       Skip loading plugin aliases"
  print "  ${__ZERT_CLR_CYAN}--no-completion${__ZERT_CLR_RESET}  Skip adding completions to fpath"
  print "  ${__ZERT_CLR_CYAN}--only-completion${__ZERT_CLR_RESET} Only add to fpath, don't source"
  print "  ${__ZERT_CLR_CYAN}--branch${__ZERT_CLR_RESET} <name>  Clone a specific branch"
  print "  ${__ZERT_CLR_CYAN}--pin${__ZERT_CLR_RESET} <sha>      Pin to an exact commit SHA"
  print ""
  print "${__ZERT_CLR_BOLD}ENVIRONMENT${__ZERT_CLR_RESET}"
  print "  ${__ZERT_CLR_YELLOW}ZERT_DIR${__ZERT_CLR_RESET}          Data directory (default: ~/.local/share/zert)"
  print "  ${__ZERT_CLR_YELLOW}ZERT_PLUGINS_DIR${__ZERT_CLR_RESET}  Plugins directory (default: \$ZERT_DIR/plugins)"
  print "  ${__ZERT_CLR_YELLOW}ZERT_LOCKFILE${__ZERT_CLR_RESET}     Lockfile path (default: \$ZDOTDIR/zert.lock)"
}
