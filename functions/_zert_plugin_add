_zert_plugin_add() {
  local source_type="$1" source_value="$2"
  shift 2

  local plugin_id
  plugin_id="$(_zert_plugin_sanitize_id "$source_type" "$source_value")"
  if [[ -z "$plugin_id" ]]; then
    _zert_ui_error "Failed to generate plugin ID for: $source_value"
    return 1
  fi

  if [[ "${__ZERT_LOADED_PLUGINS[(i)$plugin_id]}" -le ${#__ZERT_LOADED_PLUGINS} ]]; then
    return 0
  fi

  if [[ "$source_type" == "local" ]]; then
    local plugin_dir="$source_value"
  else
    local plugin_dir="$ZERT_PLUGINS_DIR/$plugin_id"
  fi

  local plugin_exists=true
  _zert_plugin_ensure_exists "$source_type" "$source_value" || plugin_exists=false

  local sync_action="synced"
  $plugin_exists && sync_action="$(_zert_plugin_ensure_sync "$plugin_id" "$source_type" "$source_value" "$@")"

  if $plugin_exists && [[ "$sync_action" == "synced" ]]; then
    _zert_plugin_source "$plugin_dir" "$source_type" "$@" || return 1
    __ZERT_LOADED_PLUGINS+=("$plugin_id")
    return 0
  fi

  _zert_ui_task_start "Configuring plugin **${plugin_id}**..."
  local subtask_idx=0

  if ! $plugin_exists; then
    _zert_ui_subtask_start $subtask_idx "Cloning repository"
    _zert_plugin_clone "$plugin_id" "$source_type" "$source_value" "$@" 2>&1 | _zert_ui_subtask_log 4
    if [[ ${pipestatus[1]} -ne 0 ]]; then
      _zert_ui_subtask_update $subtask_idx "Clone failed!"
      _zert_ui_subtask_end $subtask_idx "fail"
      _zert_ui_task_end "fail" "failed to clone the repository with git."
      return 1
    fi
    _zert_ui_subtask_update $subtask_idx "Cloned repository"
    _zert_ui_subtask_end $subtask_idx "ok"
    (( subtask_idx++ ))
  fi

  sync_action="$(_zert_plugin_ensure_sync "$plugin_id" "$source_type" "$source_value" "$@")"
  if [[ "$sync_action" != "synced" ]]; then
    _zert_ui_subtask_start $subtask_idx "Cleaning compiled files"
    find "$plugin_dir" -name "*.zwc" -type f -delete  2>&1 | _zert_ui_subtask_log 
    if [[ ${pipestatus[1]} -ne 0 ]]; then
      _zert_ui_subtask_update $subtask_idx "Cleaning compiled files failed!"
      _zert_ui_subtask_end $subtask_idx "fail"
      _zert_ui_task_end "fail" "failed to clean compiled files."
      return 1
    fi
    _zert_ui_subtask_update $subtask_idx "Cleaned compiled files"
    _zert_ui_subtask_end $subtask_idx "ok"
    (( subtask_idx++ ))


    case "$sync_action" in
      register)
        _zert_ui_subtask_start $subtask_idx "Registering plugin in lockfile"
        _zert_plugin_register "$plugin_id" "$source_type" "$source_value" "$@" 2>&1 | _zert_ui_subtask_log 4
        if [[ ${pipestatus[1]} -ne 0 ]]; then
          _zert_ui_subtask_update $subtask_idx "Registering plugin in lockfile failed!"
          _zert_ui_subtask_end $subtask_idx "fail"
          _zert_ui_task_end "fail" "failed to register plugin in lockfile."
          return 1
        fi
        _zert_ui_subtask_update $subtask_idx "Registered plugin in lockfile"
        _zert_ui_subtask_end $subtask_idx "ok"
        (( subtask_idx++ ))
        ;;
      checkout)
        _zert_ui_subtask_start $subtask_idx "Checking out locked version"
        _zert_plugin_checkout "$plugin_id" "$source_type" "$source_value" "$@" 2>&1 | _zert_ui_subtask_log 4
        if [[ ${pipestatus[1]} -ne 0 ]]; then
          _zert_ui_subtask_update $subtask_idx "Checking out locked version failed!"
          _zert_ui_subtask_end $subtask_idx "fail"
          _zert_ui_task_end "fail" "failed to checkout locked version."
          return 1
        fi
        _zert_ui_subtask_update $subtask_idx "Checked out locked version"
        _zert_ui_subtask_end $subtask_idx "ok"
        (( subtask_idx++ ))
        ;;
      pull)
        _zert_ui_subtask_start $subtask_idx "Pulling to match locked version"
        _zert_plugin_pull     "$plugin_id" "$source_type" "$source_value" "$@" 2>&1 | _zert_ui_subtask_log 4
        if [[ ${pipestatus[1]} -ne 0 ]]; then
          _zert_ui_subtask_update $subtask_idx "Pulling to match locked version failed!"
          _zert_ui_subtask_end $subtask_idx "fail"
          _zert_ui_task_end "fail" "failed to pull to match locked version."
          return 1
        fi
        _zert_ui_subtask_update $subtask_idx "Pulled to match locked version"
        _zert_ui_subtask_end $subtask_idx "ok"
        (( subtask_idx++ ))

        _zert_ui_subtask_start $subtask_idx "Checking out locked version"
        _zert_plugin_checkout "$plugin_id" "$source_type" "$source_value" "$@" 2>&1 | _zert_ui_subtask_log 4
        if [[ ${pipestatus[1]} -ne 0 ]]; then
          _zert_ui_subtask_update $subtask_idx "Checking out locked version failed!"
          _zert_ui_subtask_end $subtask_idx "fail"
          _zert_ui_task_end "fail" "failed to checkout locked version."
          return 1
        fi
        _zert_ui_subtask_update $subtask_idx "Checked out locked version"
        _zert_ui_subtask_end $subtask_idx "ok"
        (( subtask_idx++ ))

        ;;
    esac
    _zert_ui_subtask_start $subtask_idx "Compiling files"
    _zert_plugin_compile "$plugin_dir" 2>&1 | _zert_ui_subtask_log 4
    if [[ ${pipestatus[1]} -ne 0 ]]; then
      _zert_ui_subtask_update $subtask_idx "Compiling files failed!"
      _zert_ui_subtask_end $subtask_idx "fail"
      _zert_ui_task_end "fail" "failed to compile plugin files."
      return 1
    fi
    _zert_ui_subtask_update $subtask_idx "Compiled files"
    _zert_ui_subtask_end $subtask_idx "ok"
    (( subtask_idx++ ))
  fi

  _zert_ui_subtask_start $subtask_idx "Sourcing plugin"
  _zert_plugin_source "$plugin_dir" "$source_type" "$@" || {
    _zert_ui_subtask_update $subtask_idx "Sourcing plugin failed!"
    _zert_ui_subtask_end $subtask_idx "fail"
    _zert_ui_task_end "fail" "failed to source plugin after configuration."
    return 1
  }
  _zert_ui_subtask_update $subtask_idx "Sourced plugin"
  _zert_ui_subtask_end $subtask_idx "ok"

  _zert_ui_task_update "Configured plugin **${plugin_id}**"
  _zert_ui_task_end "ok"

  __ZERT_LOADED_PLUGINS+=("$plugin_id")
  return 0
}
