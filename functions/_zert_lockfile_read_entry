_zert_lockfile_read_entry() {
  local plugin_id="$1"

  [[ ! -f "$ZERT_LOCKFILE" ]] && return 1

  local line
  while IFS= read -r line; do
    # Skip comments and empty lines
    [[ "$line" = \#* || -z "$line" ]] && continue
    # Skip version header
    [[ "$line" = version::* ]] && continue

    local -a parts
    parts=("${(@s/::/)line}")

    if [[ "${parts[1]}" = "$plugin_id" ]]; then
      print -n "$line"
      return 0
    fi
  done < "$ZERT_LOCKFILE"

  return 1
}
