_zert_ui_log() {
  local __ZERT_CLR_RESET __ZERT_CLR_BLUE __ZERT_CLR_BOLD
  if [[ -z "$NO_COLOR" ]]; then
    __ZERT_CLR_RESET=$'\033[0m'
    __ZERT_CLR_BLUE=$'\033[34m'
    __ZERT_CLR_BOLD=$'\033[1m'
  else
    __ZERT_CLR_RESET=''
    __ZERT_CLR_BLUE=''
    __ZERT_CLR_BOLD=''
  fi
  print -u2 "${__ZERT_CLR_BLUE}•${__ZERT_CLR_RESET} $(_zert_ui_emphasize "$*")"
}
