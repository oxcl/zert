_zert_ui_subtask_log(){
    local max_lines="${1:-4}"
    print -r "log_max=$max_lines" >&4

    while IFS= read -d $'\r' -r line; do
        [[ -z "$line" ]] && continue
        # Escape protocol: \ -> \\, newline -> \n, = -> \=
        print -r "log_line=${${${${line}//\\/\\\\}//$'\n'/\\n}//=/\\=}" >&4
    done
}
