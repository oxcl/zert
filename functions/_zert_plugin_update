_zert_plugin_update() {
  local plugin_id="$1" source_type="$2" source_value="$3" plugin_dir="$4"
  shift 4

  git -C "$plugin_dir" pull --ff-only 2>&1 || return 1

  local commit_sha=""
  commit_sha="$(git -C "$plugin_dir" rev-parse HEAD 2>/dev/null)"
  _zert_lockfile_write_entry "$plugin_id" "$source_type" "$source_value" "$commit_sha" "$@"
  return 0
}
