_zert_ui_error() {
  local __ZERT_CLR_RESET __ZERT_CLR_RED __ZERT_CLR_BOLD
  if [[ -z "$NO_COLOR" ]]; then
    __ZERT_CLR_RESET=$'\033[0m'
    __ZERT_CLR_RED=$'\033[31m'
    __ZERT_CLR_BOLD=$'\033[1m'
  else
    __ZERT_CLR_RESET=''
    __ZERT_CLR_RED=''
    __ZERT_CLR_BOLD=''
  fi
  print -u2 "${__ZERT_CLR_RED}✗${__ZERT_CLR_RESET} ${__ZERT_CLR_RED}$(_zert_ui_emphasize "$*")${__ZERT_CLR_RESET}"
}
