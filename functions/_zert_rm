_zert_rm() {
  local tmp_prefix="${TMPDIR:-/tmp}/zert_"
  local arg
  for arg in "$@"; do
    [[ "$arg" == -* ]] && continue
    [[ -z "$arg" ]] && continue
    [[ "$arg" == "$ZERT_PLUGINS_DIR"/* ]] && continue
    [[ "$arg" == "$ZERT_DIR"/* ]] && continue
    [[ "$arg" == "$tmp_prefix"* ]] && continue
    [[ "$arg" == "$ZERT_LOCKFILE".tmp.* ]] && continue
    _zert_ui_error "_zert_rm: refusing to delete path outside zert directories: $arg"
    return 1
  done
  command rm "$@"
}
