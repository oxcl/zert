_zert_ui_emphasize() {
  local text="$*"
  local __ZERT_CLR_RESET __ZERT_CLR_ITALIC __ZERT_CLR_YELLOW
  if [[ -z "$NO_COLOR" ]]; then
    __ZERT_CLR_RESET=$'\033[0m'
    __ZERT_CLR_YELLOW=$'\033[33m'
    __ZERT_CLR_ITALIC=$'\033[3m'
  else
    __ZERT_CLR_RESET=''
    __ZERT_CLR_YELLOW=''
    __ZERT_CLR_ITALIC=''
  fi
  setopt localoptions extendedglob
  text="${text//(#b)\*\*([^*]##)\*\*/${__ZERT_CLR_YELLOW}${__ZERT_CLR_ITALIC}${match[1]}${__ZERT_CLR_RESET}}"
  print -n "$text"
}
