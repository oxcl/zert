_zert_parse_flags() {
  local key="$1"
  shift

  [[ -n "$key" ]] || return 0
  key="${key//_/-}"

  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--$key" ]]; then
      shift
      if [[ $# -eq 0 || "$1" == --* ]]; then
        print -n "true"
      else
        print -n "$1"
      fi
      return
    fi
    shift
  done

  print -n ""
}
