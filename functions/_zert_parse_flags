_zert_parse_flags() {
  local key=""
  if [[ $# -gt 0 ]]; then
    local last_arg="${@[-1]}"
    if [[ "$last_arg" != --* ]]; then
      key="$last_arg"
      key="${key//_/-}"
      set -- "${@[1,-2]}"
    fi
  fi

  [[ -n "$key" ]] || return 0

  while [[ $# -gt 0 ]]; do
    if [[ "$1" == "--$key" ]]; then
      shift
      if [[ $# -eq 0 || "$1" == --* ]]; then
        print -n "true"
      else
        print -n "$1"
      fi
      return
    fi
    shift
  done

  print -n ""
}
