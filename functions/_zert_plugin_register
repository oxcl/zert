_zert_plugin_register() {
  local plugin_id="$1" source_type="$2" source_value="$3"
  shift 3
  local plugin_dir="$ZERT_PLUGINS_DIR/$plugin_id"

  local commit_sha=""
  commit_sha="$(git -C "$plugin_dir" rev-parse HEAD 2>/dev/null)"
  if [[ -z "$commit_sha" ]]; then
    return 1
  fi

  _zert_lockfile_write_entry "$plugin_id" "$source_type" "$source_value" "$commit_sha" "$@" 
  return 0
}
